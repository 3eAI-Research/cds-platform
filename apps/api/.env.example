# =============================================================================
# CDS Platform — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Application ---
PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://cds:cds_dev_password@localhost:5432/cds_platform?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

