# =============================================================================
# CDS Platform — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Application ---
PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://cds:cds_dev_password@localhost:5432/cds_platform?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Keycloak (Phase 2 — stub auth in MVP) ---
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=cds
# KEYCLOAK_CLIENT_ID=cds-api
# KEYCLOAK_CLIENT_SECRET=

# --- AI Agent (Mistral) ---
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-large-latest
MISTRAL_VISION_MODEL=pixtral-large-latest

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Stripe Credits ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- MinIO / S3 ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=cds-uploads

# --- Kafka (Phase 2) ---
# KAFKA_BROKERS=localhost:9092
