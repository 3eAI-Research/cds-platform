// =============================================================================
// Credit Schema — Credit balance, ledger, and Stripe payment transactions
//
// Implements a credit/kontör system for the AI assistant.
// Packs: 5 / 20 / 50 credits via Stripe hosted checkout.
// All monetary amounts stored as integer cents.
//
// Cross-module refs: userId — UUID only, no FK.
//
// @see docs/domain-model/credit.ts
// =============================================================================

// --- Credit (Kredit/Kontör) ---

/// A user's credit balance. One record per user.
model Credit {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid // cross-schema ref → shared.user_references
  balance         Int       @default(0) @map("balance")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("credits")
  @@schema("credit")
}

// --- Credit Ledger (Kontobewegung) ---

/// An immutable ledger entry for every credit change.
/// Types: PURCHASE (buy credits), SPEND (use credits), REFUND, ADJUSTMENT
model CreditLedger {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid // cross-schema ref → shared.user_references
  type            String    @map("type") // PURCHASE | SPEND | REFUND | ADJUSTMENT
  amount          Int       @map("amount") // positive for add, negative for deduct
  balanceAfter    Int       @map("balance_after")
  action          String?   @map("action") // e.g., "agent_session_start"
  referenceId     String?   @map("reference_id") // e.g., session or transaction ID
  description     String?   @map("description")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("credit_ledger")
  @@schema("credit")
}

// --- Credit Payment Transaction (Kredit-Zahlungstransaktion) ---

/// A Stripe checkout session for purchasing credit packs.
model CreditPaymentTransaction {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid // cross-schema ref → shared.user_references
  stripeSessionId String    @unique @map("stripe_session_id")
  packId          String    @map("pack_id") // e.g., "pack_5", "pack_20", "pack_50"
  credits         Int       @map("credits")
  amountCents     Int       @map("amount_cents")
  currency        String    @default("eur") @map("currency") @db.VarChar(3)
  status          String    @default("pending") @map("status") // pending | completed | failed | expired

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz

  @@index([userId])
  @@map("credit_payment_transactions")
  @@schema("credit")
}

// --- Credit Processed Events ---

model CreditProcessedEvent {
  idempotencyKey String   @id @map("idempotency_key")
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
  @@schema("credit")
}
