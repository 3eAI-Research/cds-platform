// =============================================================================
// Review Schema — Bi-directional rating system (Bewertung)
//
// CDS trust mechanism: customer rates provider AND provider rates customer.
// OAK had separate comment entities per domain — we unify into one Review entity.
//
// Aspect ratings stored as JSON for flexibility (PUNCTUALITY, CAREFULNESS, etc.)
// Review aggregates denormalized to provider module via events.
//
// @see docs/domain-model/review.ts
// =============================================================================

// --- Review (Bewertung) ---

/// A review/rating for a completed service.
/// Both parties review each other after service completion.
model Review {
  id              String    @id @default(uuid()) @db.Uuid
  demandId        String    @map("demand_id") @db.Uuid // cross-schema ref → demand.demands
  contractId      String    @map("contract_id") @db.Uuid // cross-schema ref → contract.contracts

  reviewerUserId  String    @map("reviewer_user_id") @db.Uuid // who wrote the review
  revieweeUserId  String    @map("reviewee_user_id") @db.Uuid // who is being reviewed
  direction       String    @map("direction") // CUSTOMER_TO_PROVIDER | PROVIDER_TO_CUSTOMER

  rating          Int       @map("rating") // 1-5 (Sterne)
  /// @pii
  comment         String?   @map("comment") // may contain personal details

  /// AspectRatings as JSON: [{ aspect: "PUNCTUALITY", rating: 5 }, ...]
  aspectRatings   Json?     @map("aspect_ratings")

  status          String    @map("status") // PUBLISHED | FLAGGED | REMOVED

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdBy       String    @map("created_by") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")

  @@unique([contractId, direction]) // one review per direction per contract
  @@index([revieweeUserId])
  @@index([direction])
  @@index([status])
  @@map("reviews")
  @@schema("review")
}

// --- Review Aggregate (Cached rating statistics) ---

/// Aggregated review statistics per user per direction.
/// Source of truth for rating data — provider module denormalizes from here.
model ReviewAggregate {
  id                 String   @id @default(uuid()) @db.Uuid
  revieweeUserId     String   @map("reviewee_user_id") @db.Uuid
  direction          String   @map("direction") // CUSTOMER_TO_PROVIDER | PROVIDER_TO_CUSTOMER
  averageRating      Float    @map("average_rating")
  totalReviews       Int      @map("total_reviews")
  /// Rating distribution: { "1": 0, "2": 1, "3": 5, "4": 12, "5": 8 }
  ratingDistribution Json     @map("rating_distribution")

  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([revieweeUserId, direction])
  @@map("review_aggregates")
  @@schema("review")
}

// --- Review Processed Events ---

model ReviewProcessedEvent {
  idempotencyKey String   @id @map("idempotency_key")
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
  @@schema("review")
}
