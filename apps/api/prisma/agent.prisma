// =============================================================================
// Agent Schema — AI Moving Assistant sessions, messages, and reports
//
// Tracks conversational sessions with the AI assistant, stores messages,
// and persists generated moving reports (man-hour + km calculations).
//
// Cross-module refs: userId, demandId — UUID only, no FK.
//
// @see docs/domain-model/agent.ts
// =============================================================================

// --- Agent Session (AI-Sitzung) ---

/// An AI assistant conversation session.
/// States: ACTIVE → COLLECTING → SUMMARY → SUBMITTED → COMPLETED
///         (or CANCELLED / EXPIRED at any point)
model AgentSession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid // cross-schema ref → shared.user_references
  state           String    @default("ACTIVE") @map("state") // ACTIVE | COLLECTING | SUMMARY | SUBMITTED | COMPLETED | CANCELLED | EXPIRED
  extractedData   Json?     @map("extracted_data") @db.JsonB
  demandId        String?   @map("demand_id") @db.Uuid // cross-schema ref → demand.demands
  reportId        String?   @map("report_id") @db.Uuid // cross-schema ref → agent.agent_reports
  completionPct   Int       @default(0) @map("completion_pct")
  messageCount    Int       @default(0) @map("message_count")
  photoCount      Int       @default(0) @map("photo_count")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  messages        AgentMessage[]

  @@index([userId])
  @@index([state])
  @@map("agent_sessions")
  @@schema("agent")
}

// --- Agent Message (AI-Nachricht) ---

/// A single message in an agent conversation session.
model AgentMessage {
  id              String    @id @default(uuid()) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  role            String    @map("role") // user | assistant | system
  content         String    @map("content") @db.Text
  metadata        Json?     @map("metadata") @db.JsonB

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  session         AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("agent_messages")
  @@schema("agent")
}

// --- Agent Report (Umzugsbericht) ---

/// A generated moving report with man-hour + km calculations.
model AgentReport {
  id              String    @id @default(uuid()) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid // cross-schema ref → shared.user_references
  demandId        String?   @map("demand_id") @db.Uuid // cross-schema ref → demand.demands
  planData        Json      @map("plan_data") @db.JsonB
  pdfPath         String?   @map("pdf_path")
  downloadUrl     String?   @map("download_url")

  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([sessionId])
  @@index([userId])
  @@map("agent_reports")
  @@schema("agent")
}

// --- Photo Storage (user-opted photo retention) ---

/// Tracks photos that users chose to keep after AI analysis.
/// Default: photos are deleted after processing.
/// If kept: 1 month free, then monthly billing (1-3 EUR).
model PhotoStorage {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  storageKey      String    @map("storage_key")          // MinIO object key
  fileName        String    @map("file_name")
  sizeBytes       Int       @map("size_bytes")
  mimeType        String    @map("mime_type")
  billingStatus   String    @default("FREE") @map("billing_status") // FREE | BILLED | EXPIRED
  freeUntil       DateTime  @map("free_until") @db.Timestamptz      // 1 month from upload
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([billingStatus])
  @@index([freeUntil])
  @@map("photo_storage")
  @@schema("agent")
}

// --- Agent Processed Events ---

model AgentProcessedEvent {
  idempotencyKey String   @id @map("idempotency_key")
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
  @@schema("agent")
}
