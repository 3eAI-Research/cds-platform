// =============================================================================
// Offer Schema — Provider bidding mechanism
//
// Commission calculation: totalPrice × commissionRate = commissionAmount
// CDS principle: transparent pricing with price breakdown.
//
// @see docs/domain-model/offer.ts
// =============================================================================

model Offer {
  id                  String    @id @default(uuid()) @db.Uuid
  demandId            String    @map("demand_id") @db.Uuid // cross-schema ref → demand.demands
  providerUserId      String    @map("provider_user_id") @db.Uuid // cross-schema ref
  providerCompanyId   String    @map("provider_company_id") @db.Uuid // cross-schema ref → provider.companies

  status              String    @map("status") // OfferStatus enum

  // --- Pricing (integer cents, EUR) ---
  totalPriceAmount    Int       @map("total_price_amount") // cents
  totalPriceCurrency  String    @default("EUR") @map("total_price_currency") @db.VarChar(3)
  commissionAmount    Int       @map("commission_amount") // cents
  commissionRate      Float     @map("commission_rate") // e.g., 0.04 = 4%
  providerNetAmount   Int       @map("provider_net_amount") // cents
  vatAmount           Int       @map("vat_amount") // cents
  vatRate             Float     @map("vat_rate") // e.g., 0.19 = 19%

  // --- Offer details ---
  message             String?   @map("message")
  submittedAt         DateTime? @map("submitted_at")
  validUntil          DateTime  @map("valid_until")

  // --- Price Breakdown (JSON — optional detailed breakdown) ---
  /// OfferPriceBreakdown as JSON: { baseTransportPrice, assemblyCost, kitchenCost, packingCost, halteverbotCost, additionalCharges }
  priceBreakdown      Json?     @map("price_breakdown")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdBy           String    @map("created_by") @db.Uuid
  deletedAt           DateTime? @map("deleted_at")

  @@index([demandId])
  @@index([providerCompanyId])
  @@index([status])
  @@index([demandId, status])
  @@map("offers")
  @@schema("offer")
}

// --- Offer Processed Events ---

model OfferProcessedEvent {
  idempotencyKey String   @id @map("idempotency_key")
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
  @@schema("offer")
}
