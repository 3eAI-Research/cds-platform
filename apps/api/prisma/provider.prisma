// =============================================================================
// Provider Schema — Moving company (Umzugsunternehmen) management
//
// Owns: companies, employees, documents, onboarding.
// CDS differentiator: deposit/stake mechanism for economic regulation.
//
// Denormalized stats (averageRating, reviewCount) updated via review events.
// Stripe Connect account created during onboarding.
//
// @see docs/domain-model/provider.ts
// =============================================================================

// --- Provider Company (Umzugsunternehmen) ---

/// A moving company registered on the CDS platform.
/// Onboarding: Register → Profile → Deposit → ACTIVE → Can submit offers.
model ProviderCompany {
  id                       String    @id @default(uuid()) @db.Uuid
  ownerUserId              String    @map("owner_user_id") @db.Uuid // cross-schema ref → shared.user_references

  /// @pii
  name                     String    @map("name")
  /// @pii
  email                    String    @map("email")
  /// @pii
  phoneNumber              String    @map("phone_number")
  /// @pii
  taxNumber                String    @map("tax_number") // Steuernummer / USt-IdNr.

  status                   String    @map("status") // ProviderStatus enum

  // --- Deposit/Stake (Kaution — CDS core mechanism) ---
  depositAmount            Int       @default(0) @map("deposit_amount") // EUR cents
  depositCurrency          String    @default("EUR") @map("deposit_currency") @db.VarChar(3)
  depositPaidAt            DateTime? @map("deposit_paid_at")
  depositPaymentReference  String?   @map("deposit_payment_reference") // Stripe PaymentIntent ID

  // --- Payment (Stripe Connect) ---
  stripeConnectedAccountId String?   @map("stripe_connected_account_id")

  // --- Service Coverage (Einsatzgebiet) ---
  /// PLZ prefixes this provider serves. Example: ['40','41','42','45']
  supportedPostCodePrefixes String[] @map("supported_post_code_prefixes")

  // --- Denormalized stats (from review module events) ---
  averageRating            Float?    @map("average_rating") // 1.0-5.0
  reviewCount              Int       @default(0) @map("review_count")
  completedJobCount        Int       @default(0) @map("completed_job_count")

  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  createdBy                String    @map("created_by") @db.Uuid
  deletedAt                DateTime? @map("deleted_at")

  employees                ProviderEmployee[]
  documents                ProviderDocument[]
  address                  ProviderAddress?

  @@index([ownerUserId])
  @@index([status])
  @@map("provider_companies")
  @@schema("provider")
}

// --- Provider Employee (Mitarbeiter) ---

/// Links a Keycloak user to a provider company with a role.
model ProviderEmployee {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid // cross-schema ref → shared.user_references
  role      String   @map("role") // OWNER | DISPATCHER | WORKER

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by") @db.Uuid

  company   ProviderCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("provider_employees")
  @@schema("provider")
}

// --- Provider Document (Firmendokument) ---

/// Official documents: Gewerbeschein, Versicherungsnachweis, Handelsregisterauszug.
/// GDPR: @pii — hard-deleted with company (CASCADE). Right to erasure via DELETE endpoint.
model ProviderDocument {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  type             String    @map("type") // BUSINESS_LICENSE | INSURANCE | COMMERCIAL_REGISTER | OTHER
  /// @pii — binary file content stored as PostgreSQL bytea
  fileData         Bytes     @map("file_data")
  mimeType         String    @map("mime_type") @db.VarChar(100) // e.g. application/pdf, image/jpeg
  fileSize         Int       @map("file_size") // bytes
  /// @pii
  originalFilename String    @map("original_filename")
  verified         Boolean   @default(false) @map("verified")
  verifiedAt       DateTime? @map("verified_at")
  verifiedBy       String?   @map("verified_by") @db.Uuid
  rejectionReason  String?   @map("rejection_reason") // why admin rejected this document

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        String    @map("created_by") @db.Uuid

  company          ProviderCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("provider_documents")
  @@schema("provider")
}

// --- Provider Address (Firmenadresse) ---

/// Company address — owned by provider schema (not cross-schema ref to transport.addresses).
/// Separate from demand from/to addresses. GDPR: deleted with company.
model ProviderAddress {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @unique @map("company_id") @db.Uuid
  /// @pii
  street      String  @map("street")
  /// @pii
  houseNumber String  @map("house_number")
  postCode    String  @map("post_code") @db.VarChar(10)
  placeName   String  @map("place_name")
  countryCode String  @default("DE") @map("country_code") @db.VarChar(3)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     ProviderCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("provider_addresses")
  @@schema("provider")
}

// --- Provider Processed Events ---

model ProviderProcessedEvent {
  idempotencyKey String   @id @map("idempotency_key")
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
  @@schema("provider")
}
